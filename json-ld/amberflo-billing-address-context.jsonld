{
  "@context": {
    "@version": 1.1,
    "amberflo": "https://amberflo.io/schema/",
    "schema": "https://schema.org/",
    "dcterms": "http://purl.org/dc/terms/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "Address": "amberflo:Address",
    "verified": {
      "@id": "amberflo:verified",
      "@type": "xsd:boolean"
    },
    "line1": {
      "@id": "amberflo:line1",
      "@type": "xsd:string"
    },
    "state": {
      "@id": "amberflo:state",
      "@type": "xsd:string"
    },
    "city": {
      "@id": "amberflo:city",
      "@type": "xsd:string"
    },
    "postalCode": {
      "@id": "amberflo:postalCode",
      "@type": "xsd:string"
    },
    "country": {
      "@id": "amberflo:country",
      "@type": "xsd:string"
    }
  }
}